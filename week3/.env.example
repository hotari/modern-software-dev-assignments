# Copy to .env. Loaded automatically by both entrypoints.

# GitHub personal access token used for UPSTREAM calls (optional, but recommended).
# Without it the server uses GitHub's 60 req/h unauthenticated quota.
# Scopes: `public_repo` is enough for the bundled tools.
GITHUB_TOKEN=

# Shared secret that HTTP clients must present as `Authorization: Bearer <key>`.
# Required when running the HTTP transport; ignored by the STDIO transport.
# NEVER forwarded to GitHub.
MCP_API_KEY=change-me

# HTTP transport bind address. Defaults shown.
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8765

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
